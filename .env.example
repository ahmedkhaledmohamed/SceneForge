# Together AI API key (required for real generation; fake models work without it)
TOGETHER_API_KEY=

# RunPod self-hosted backend (models runpod-flux / runpod-wan-i2v)
# Setup runbook: runpod-worker/README.md
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Studio home directory (default: ~/SceneForge)
# SCENEFORGE_HOME=~/SceneForge

# Optional global default overrides (per-project settings and --model flags win)
# SCENEFORGE_IMAGE_MODEL=flux-schnell
# SCENEFORGE_VIDEO_MODEL=seedance-2.0
# SCENEFORGE_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
